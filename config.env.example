# RunPod credentials
RUNPOD_API_KEY=your_runpod_api_key_here

# HuggingFace model configuration
# Model ID from huggingface.co/models (e.g. google-bert/bert-base-uncased)
HF_MODEL_ID=google-bert/bert-base-uncased
# Optional: required for gated models (e.g. Meta Llama)
HF_TOKEN=

# Task type for the HuggingFace pipeline
# Options: text-classification, text-generation, token-classification,
#          question-answering, summarization, translation, fill-mask, zero-shot-classification
MODEL_TASK=text-classification

# JupyterLab access (leave empty to disable JupyterLab)
JUPYTER_PASSWORD=changeme123

# Inference server port (exposed via RunPod HTTP proxy)
INFERENCE_PORT=8000

# Pod hardware configuration
GPU_TYPE="NVIDIA GeForce RTX 4090"
GPU_COUNT=1
CLOUD_TYPE=SECURE
DATACENTER_ID=US-TX-1

# Storage
CONTAINER_DISK_GB=50
# Network volume size in GB (persistent, survives pod restarts)
# Set to 0 to skip network volume creation and use ephemeral storage
NETWORK_VOLUME_GB=100
NETWORK_VOLUME_NAME=hf-model-cache

# Pod naming
POD_NAME=hf-inference-pod
